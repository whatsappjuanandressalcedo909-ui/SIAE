rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'firstName', 'lastName', 'documentType', 'documentNumber', 'phoneNumber']) &&
             data.keys().hasOnly(['email', 'createdAt', 'firstName', 'middleName', 'lastName', 'secondLastName', 'documentType', 'documentNumber', 'phoneNumber', 'photoURL']) &&
             data.email is string && data.email.size() <= 150 &&
             data.createdAt is timestamp &&
             data.firstName is string && data.firstName.size() <= 100 &&
             (!data.keys().hasAny(['middleName']) || (data.middleName is string && data.middleName.size() <= 100)) &&
             data.lastName is string && data.lastName.size() <= 100 &&
             (!data.keys().hasAny(['secondLastName']) || (data.secondLastName is string && data.secondLastName.size() <= 100)) &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 2000)) &&
             data.documentType in ['T.I', 'C.C', 'C.E'] &&
             data.documentNumber is string && data.documentNumber.size() <= 20 &&
             data.phoneNumber is string && data.phoneNumber.matches('^3[0-9]{9}$');
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      
      allow create: if isSignedIn() &&
                       isValidId(userId) &&
                       isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == request.time;
                       
      allow update: if isSignedIn() &&
                       isValidId(userId) &&
                       isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['email', 'firstName', 'middleName', 'lastName', 'secondLastName', 'documentType', 'documentNumber', 'phoneNumber', 'photoURL']);
                       
      allow delete: if isSignedIn() && isOwner(userId);
    }

    function isValidDocRegistry(data) {
      return data.keys().hasAll(['userId']) && data.keys().size() == 1 && data.userId is string;
    }

    match /documentNumbers/{docNum} {
      allow get: if isSignedIn();
      allow list: if false;
      
      allow create: if isSignedIn() && isValidId(docNum) && isValidDocRegistry(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(docNum) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
